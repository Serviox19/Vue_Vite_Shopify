{% comment %}
  This section is used in the product template to render product page with
  media, content, and add-to-cart form.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/product
{% endcomment %}

{% assign current_variant = product.selected_or_first_available_variant %}

<div class="product max-w-6xl mx-auto px-4 py-10 grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-start">
  {% comment %} Media {% endcomment %}
  <div class="product__media">
    {% if product.featured_image %}
      <img
        src="{{ product.featured_image | image_url: width: 1000 }}"
        alt="{{ product.featured_image.alt | escape }}"
        width="1000"
        height="1000"
        class="w-full aspect-square object-cover rounded-lg bg-gray-100"
        loading="eager"
      >
    {% else %}
      <div class="w-full aspect-square rounded-lg bg-gray-100"></div>
    {% endif %}

    {% if product.images.size > 1 %}
      <div class="grid grid-cols-4 gap-3 mt-3">
        {% for image in product.images offset: 1 limit: 8 %}
          <img
            src="{{ image | image_url: width: 240 }}"
            alt="{{ image.alt | escape }}"
            width="120"
            height="120"
            class="w-full aspect-square object-cover rounded-md bg-gray-100"
            loading="lazy"
          >
        {% endfor %}
      </div>
    {% endif %}
  </div>

  {% comment %} Info {% endcomment %}
  <div class="product__info lg:sticky lg:top-8">
    <h1 class="text-2xl md:text-3xl font-bold leading-tight">{{ product.title | escape }}</h1>

    <div class="flex items-baseline gap-3 mt-3">
      <span class="text-2xl font-semibold tabular-nums">{{ current_variant.price | money }}</span>
      {% if current_variant.compare_at_price > current_variant.price %}
        <s class="text-lg text-gray-400 tabular-nums">{{ current_variant.compare_at_price | money }}</s>
        <span class="text-xs font-semibold uppercase tracking-wide text-red-600 bg-red-50 px-2 py-1 rounded">Sale</span>
      {% endif %}
    </div>

    {% form 'product', product, class: 'mt-6 space-y-4' %}
      {% unless product.has_only_default_variant %}
        <div>
          <label for="variant-select" class="block text-sm font-medium mb-1.5">Variant</label>
          <select
            id="variant-select"
            name="id"
            class="w-full h-11 px-3 border border-gray-300 rounded-md bg-white"
          >
            {% for variant in product.variants %}
              <option
                value="{{ variant.id }}"
                {% if variant == current_variant %}selected="selected"{% endif %}
                {% unless variant.available %}disabled{% endunless %}
              >
                {{ variant.title }}{% unless variant.available %} — Sold out{% endunless %} · {{ variant.price | money }}
              </option>
            {% endfor %}
          </select>
        </div>
      {% else %}
        <input type="hidden" name="id" value="{{ current_variant.id }}">
      {% endunless %}

      <div class="w-28">
        <label for="quantity" class="block text-sm font-medium mb-1.5">Quantity</label>
        <input
          type="number"
          id="quantity"
          name="quantity"
          value="1"
          min="1"
          inputmode="numeric"
          class="w-full h-11 px-3 text-center border border-gray-300 rounded-md tabular-nums"
        >
      </div>

      {% comment %}
        Vue add-to-cart island — adds via the shared cart store (no page refresh)
        and opens the drawer. Variant/quantity wiring to the selector above is
        Step 3 (ProductForm); for now it adds the current/first-available variant.
      {% endcomment %}
      {% if product.available %}
        <div
          data-vue-mount="add-to-cart"
          data-props='{"productId": {{ product.id | json }}, "variantId": {{ current_variant.id | json }}, "buttonText": "Add to cart"}'
        ></div>
      {% else %}
        <button
          type="button"
          disabled
          class="block w-full bg-black text-white text-center px-6 py-3.5 rounded-md font-medium opacity-40 cursor-not-allowed"
        >
          Sold out
        </button>
      {% endif %}

      {{ form | payment_button }}
    {% endform %}

    {% if product.description != blank %}
      <div class="product__description rte mt-8 pt-8 border-t border-gray-200 prose-sm">
        {{ product.description }}
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "t:general.product",
  "settings": [],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
