# Vite build manifest lives in a subfolder under assets/, which Shopify rejects
# ("Theme files may not be stored in subfolders"). It's needed locally by
# vite-plugin-shopify but must never be served or pushed to the store.
assets/.vite/

# Atomic-save temp files (e.g. collection.liquid.tmp.15492.0f05a5e8b63a) created
# briefly during writes. The dev watcher can catch them mid-save and try to upload
# them, which Shopify rejects ("contains illegal characters"). Harmless but noisy.
*.tmp.*


.git
.github
node_modules
src
*.log
